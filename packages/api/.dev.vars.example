# Cloudflare Worker secrets for `wrangler dev` (--env development).
# Copy this file to `.dev.vars` and fill in real values. Do NOT commit `.dev.vars`.

# Neon Postgres connection string (use the pooled `-pooler` host for serverless).
DATABASE_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require"

# 32+ bytes of randomness, e.g. `openssl rand -base64 48`.
JWT_SECRET="replace-me-with-a-long-random-string"

# Anthropic key (only used by the AI queue consumer in Phase 7+).
AI_API_KEY=""
