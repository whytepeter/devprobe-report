    {
      "id": "bug-005",
      "timestamp": "2026-05-03T20:00:00.000Z",
      "error_message": "Shapes (rect, circle, arrow) don't start where the mouse is clicked; drawing from top of screenshot starts below the actual click point",
      "file": "annotation/AnnotationCanvas.vue",
      "root_cause": "Canvas used `object-fit: contain` CSS which letterboxes the bitmap inside the element. getBoundingClientRect() returns the full element bounds including the empty letterbox areas, so toCanvasPx() mapped coordinates against the wrong origin and scale — producing a systematic offset proportional to the letterbox size.",
      "fix": "Removed `object-contain` from canvas element. Added ResizeObserver on wrapper div to track available space reactively. Added bitmapW/bitmapH reactive refs to useAnnotationCanvas composable (updated in initCanvas). Component computes CSS display size as Math.min(wrapperW/bitmapW, wrapperH/bitmapH) * bitmap dimensions — canvas element exactly matches bitmap aspect ratio, so getBoundingClientRect() is always correct and toCanvasPx() requires no offset adjustment.",
      "tags": [
        "canvas",
        "coordinates",
        "object-fit",
        "annotation",
        "drawing"
      ],
      "related_bugs": [],
      "occurrences": 1,
      "last_seen": "2026-05-03T20:00:00.000Z"
    },
