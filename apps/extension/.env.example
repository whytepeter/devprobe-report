# Build-time settings for the extension.
# Copy to `.env` (or `.env.production`) and run `pnpm build`.

# Where the web app is hosted. Used to open /issue/:id and /extension/connect tabs.
VITE_WEB_APP_URL="http://localhost:5173"

# Where the API Worker is hosted. Used by api.ts for fetch().
VITE_API_URL="http://localhost:8787"
